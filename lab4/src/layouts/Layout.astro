---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Endfield Factory Planner — Schematic Calculator',
  description = 'The ultimate factory schematic calculator for Arknights: Endfield.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="bg-primary text-text-primary font-sans leading-relaxed overflow-x-hidden">
    <slot />
  </body>
</html>
