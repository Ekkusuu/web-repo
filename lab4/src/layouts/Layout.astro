---
import '../styles/global.css';
import site from '../data/site.json';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Endfield Factory Planner — Schematic Calculator',
  description = 'The ultimate factory schematic calculator for Arknights: Endfield.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="bg-primary text-text-primary font-sans leading-relaxed overflow-x-hidden">

    <!-- ===== NAVIGATION ===== -->
    <nav class="fixed top-0 left-0 w-full z-[1000] bg-primary/[0.92] backdrop-blur-xl border-b border-border" id="navbar">
      <div class="max-w-[1200px] mx-auto px-6 flex items-center justify-between h-16">
        <a href="#" class="text-xl font-bold text-text-primary flex items-center gap-2 hover:text-accent transition-colors">
          <span class="text-2xl text-accent">{site.siteIcon}</span> {site.siteName}
        </a>
        <button class="flex flex-col gap-[5px] bg-transparent border-none cursor-pointer p-1 md:hidden" id="navToggle" aria-label="Toggle menu">
          <span class="w-6 h-0.5 bg-text-primary transition-all"></span>
          <span class="w-6 h-0.5 bg-text-primary transition-all"></span>
          <span class="w-6 h-0.5 bg-text-primary transition-all"></span>
        </button>
        <ul class="nav-links hidden md:flex gap-2 list-none" id="navLinks">
          <li><a href="#hero" class="px-3.5 py-2 rounded-lg text-text-secondary text-sm font-medium hover:text-accent hover:bg-accent/[0.08] transition-all">Home</a></li>
          <li><a href="#features" class="px-3.5 py-2 rounded-lg text-text-secondary text-sm font-medium hover:text-accent hover:bg-accent/[0.08] transition-all">Features</a></li>
          <li><a href="#calculator" class="px-3.5 py-2 rounded-lg text-text-secondary text-sm font-medium hover:text-accent hover:bg-accent/[0.08] transition-all">Calculator</a></li>
          <li><a href="#testimonials" class="px-3.5 py-2 rounded-lg text-text-secondary text-sm font-medium hover:text-accent hover:bg-accent/[0.08] transition-all">Community</a></li>
          <li><a href="#team" class="px-3.5 py-2 rounded-lg text-text-secondary text-sm font-medium hover:text-accent hover:bg-accent/[0.08] transition-all">Team</a></li>
          <li><a href="#pricing" class="px-3.5 py-2 rounded-lg text-text-secondary text-sm font-medium hover:text-accent hover:bg-accent/[0.08] transition-all">Pricing</a></li>
          <li><a href="#faq" class="px-3.5 py-2 rounded-lg text-text-secondary text-sm font-medium hover:text-accent hover:bg-accent/[0.08] transition-all">FAQ</a></li>
          <li><a href="#contact" class="px-3.5 py-2 rounded-lg text-text-secondary text-sm font-medium hover:text-accent hover:bg-accent/[0.08] transition-all">Contact</a></li>
        </ul>
      </div>
    </nav>

    <slot />

    <!-- ===== FOOTER ===== -->
    <footer class="pt-16 bg-primary border-t border-border">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] gap-10 mb-10">
          <div>
            <a href="#" class="text-xl font-bold text-text-primary inline-block mb-3">{site.siteIcon} {site.siteName}</a>
            <p class="text-sm text-text-secondary leading-relaxed">The ultimate factory schematic calculator for Arknights: Endfield. Plan, optimize, and build.</p>
          </div>
          <div>
            <h4 class="text-xs font-bold text-text-primary uppercase tracking-wider mb-4">Navigate</h4>
            <ul class="flex flex-col gap-2">
              <li><a href="#hero" class="text-sm text-text-secondary hover:text-accent transition-colors">Home</a></li>
              <li><a href="#features" class="text-sm text-text-secondary hover:text-accent transition-colors">Features</a></li>
              <li><a href="#calculator" class="text-sm text-text-secondary hover:text-accent transition-colors">Calculator</a></li>
              <li><a href="#pricing" class="text-sm text-text-secondary hover:text-accent transition-colors">Pricing</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-bold text-text-primary uppercase tracking-wider mb-4">Resources</h4>
            <ul class="flex flex-col gap-2">
              <li><a href="#faq" class="text-sm text-text-secondary hover:text-accent transition-colors">FAQ</a></li>
              <li><a href="#testimonials" class="text-sm text-text-secondary hover:text-accent transition-colors">Community</a></li>
              <li><a href="#team" class="text-sm text-text-secondary hover:text-accent transition-colors">Team</a></li>
              <li><a href="#contact" class="text-sm text-text-secondary hover:text-accent transition-colors">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-bold text-text-primary uppercase tracking-wider mb-4">Legal</h4>
            <ul class="flex flex-col gap-2">
              <li><a href="#" class="text-sm text-text-secondary hover:text-accent transition-colors">Privacy Policy</a></li>
              <li><a href="#" class="text-sm text-text-secondary hover:text-accent transition-colors">Terms of Service</a></li>
            </ul>
          </div>
        </div>
        <div class="py-6 border-t border-border text-center">
          <p class="text-xs text-text-muted">{site.copyright}</p>
        </div>
      </div>
    </footer>

    <!-- ===== PERLICA MASCOT ===== -->
    <div class="mascot-container" id="mascot">
      <div class="mascot-bubble" id="mascotBubble">
        <div class="mascot-bubble-text" id="mascotBubbleText"></div>
        <div class="mascot-bubble-arrow"></div>
      </div>
      <div class="mascot-sprite" id="mascotSprite">
        <img src={`${import.meta.env.BASE_URL}mascot/teeth.png`} alt="Perlica — Endfield Industries Supervisor" id="mascotImg" class="mascot-img" draggable="false" data-base={import.meta.env.BASE_URL} />
      </div>
    </div>

    <script>
      // ===== NAV TOGGLE (mobile) =====
      const navToggle = document.getElementById('navToggle');
      const navLinks = document.getElementById('navLinks');
      navToggle?.addEventListener('click', () => {
        navLinks?.classList.toggle('open');
      });

      // ===== NAVBAR SCROLL =====
      const navbar = document.getElementById('navbar');
      window.addEventListener('scroll', () => {
        navbar?.classList.toggle('scrolled', window.scrollY > 20);
      });

      // ===== SMOOTH SCROLL — close mobile nav on click =====
      document.querySelectorAll('#navLinks a').forEach(link => {
        link.addEventListener('click', () => {
          navLinks?.classList.remove('open');
        });
      });

      // ===== PERLICA MASCOT SYSTEM =====
      (function() {
        const mascotContainer = document.getElementById('mascot') as HTMLElement;
        const mascotBubble = document.getElementById('mascotBubble') as HTMLElement;
        const bubbleText = document.getElementById('mascotBubbleText') as HTMLElement;
        const mascotImg = document.getElementById('mascotImg') as HTMLImageElement;

        const greetings = [
          "How are you holding up, Endministrator?",
          "Don't push yourself too hard, Endministrator. Keep yourself rested and well.",
          "Operator Perlica standing by.",
          "Prepped and ready to go.",
          "Welcome back to Endfield Industries, Endministrator.",
        ];

        const sectionDialogue: Record<string, Array<{ text: string; expr: string }>> = {
          hero: [
            { text: "Welcome to the Endfield Factory Planner! Let me show you around.", expr: 'smile' },
            { text: "This tool helps you master your factory lines — scroll down to see everything it offers!", expr: 'smile' },
            { text: "60+ recipes, 7 building types, and it's completely free. Not bad, right?", expr: 'thinking' },
            { text: "Ready to optimize? Hit that Open Calculator button to get started!", expr: 'teeth' },
          ],
          features: [
            { text: "The Recipe Tree Viewer lets you see the full production chain for any item — super useful!", expr: 'thinking' },
            { text: "The Building Calculator tells you exactly how many of each building you need.", expr: 'smile' },
            { text: "Connection Schema is my favorite — it shows how to wire everything together.", expr: 'teeth' },
            { text: "Zero setup required. No downloads, no accounts. Just pick an item and go!", expr: 'smile' },
            { text: "Max efficiency means 100% uptime — no idle machines, no bottlenecks.", expr: 'thinking' },
          ],
          calculator: [
            { text: "Here's the calculator in action! This example shows the HC Valley Battery chain.", expr: 'thinking' },
            { text: "Look at that recipe tree — HC Valley Battery needs 5 Assemblers, 2 Mixers, and more.", expr: 'teeth' },
            { text: "The connection schema shows the exact flow: raw ores go to Grinders, then Mixers, then Assemblers.", expr: 'thinking' },
            { text: "16 buildings total for one HC Valley Battery line. The planner figured that out instantly!", expr: 'smile' },
            { text: "Check the recipe database below — every building type and all its craftable items listed.", expr: 'teeth' },
            { text: "Time to come up with optimum tactics for this factory layout.", expr: 'thinking' },
          ],
          testimonials: [
            { text: "Over 2,400 active users trust this planner. The community loves it!", expr: 'smile' },
            { text: "4.9 out of 5 user rating — that's some serious approval from fellow Doctors.", expr: 'smile' },
            { text: "15,000+ calculations made so far. That's a lot of optimized factories!", expr: 'thinking' },
            { text: "DoctorKnight says their factory runs at 100% now. That's what we aim for!", expr: 'teeth' },
          ],
          team: [
            { text: "This whole thing was built by one person — Luchian Sava. Impressive dedication!", expr: 'smile' },
            { text: "A solo developer who's both an Endfield and Factorio enthusiast. My kind of person!", expr: 'thinking' },
            { text: "From the recipe database to the UI — all designed, built, and maintained by one developer.", expr: 'teeth' },
          ],
          pricing: [
            { text: "The Free tier includes all 60+ recipes, the tree viewer, building calculator, and connection schema!", expr: 'smile' },
            { text: "Pro plan at $5/month adds save/load layouts and PNG/SVG export. Worth considering!", expr: 'thinking' },
            { text: "The Team plan at $12/month includes collaboration, API access, and dedicated support.", expr: 'teeth' },
            { text: "Start for free — all the core features are right there at no cost.", expr: 'smile' },
          ],
          faq: [
            { text: "Got questions? This section has answers for the most common ones.", expr: 'thinking' },
            { text: "Yes, all recipes are sourced directly from game data — 100% accurate!", expr: 'smile' },
            { text: "It works on mobile too — fully responsive design.", expr: 'teeth' },
            { text: "Recipe changes from new patches are reflected within 24 hours. Always up to date!", expr: 'thinking' },
          ],
          contact: [
            { text: "Want to reach out? Fill in the form or join the Discord community!", expr: 'smile' },
            { text: "Found a bug? You can open a GitHub issue — the team responds quickly.", expr: 'thinking' },
            { text: "Feature requests are welcome too! Just select it from the subject dropdown.", expr: 'teeth' },
            { text: "Have questions? Send a message — the team would love to hear from you.", expr: 'smile' },
          ],
        };

        const b = (document.getElementById('mascotImg') as HTMLImageElement).dataset.base ?? '/';
        const expressions: Record<string, string[]> = {
          teeth: [`${b}mascot/teeth.png`, `${b}mascot/teeth_half_open.png`, `${b}mascot/teeth_open.png`],
          smile: [`${b}mascot/smile.png`, `${b}mascot/smile_half_open.png`, `${b}mascot/smile_open.png`],
          thinking: [`${b}mascot/thinking.png`, `${b}mascot/thinking_half_open.png`, `${b}mascot/thinking_open.png`],
        };

        let currentExpression = 'teeth';
        let mouthInterval: ReturnType<typeof setInterval> | null = null;
        let currentSection = '';
        let mascotSide = 'right';

        function setExpression(expr: string) {
          currentExpression = expr;
          if (mascotImg) mascotImg.src = expressions[expr][0];
        }

        function animateMouth(expr: string, duration: number) {
          if (mouthInterval) clearInterval(mouthInterval);
          const frames = expressions[expr];
          let frame = 0;
          mouthInterval = setInterval(() => {
            frame = (frame + 1) % frames.length;
            if (mascotImg) mascotImg.src = frames[frame];
          }, 120);
          setTimeout(() => {
            if (mouthInterval) clearInterval(mouthInterval);
            if (mascotImg) mascotImg.src = frames[0];
          }, duration);
        }

        function showBubble(text: string, expr: string) {
          setExpression(expr);
          if (bubbleText) bubbleText.textContent = text;
          mascotBubble?.classList.add('visible');
          animateMouth(expr, text.length * 55 + 500);
          setTimeout(() => {
            mascotBubble?.classList.remove('visible');
          }, Math.max(3500, text.length * 55 + 800));
        }

        function setSide(side: string) {
          mascotSide = side;
          if (side === 'left') {
            mascotContainer?.classList.remove('right-side');
            mascotContainer?.classList.add('left-side');
          } else {
            mascotContainer?.classList.remove('left-side');
            mascotContainer?.classList.add('right-side');
          }
        }

        const sections = ['hero','features','calculator','testimonials','team','pricing','faq','contact'];
        const sectionSides: Record<string, string> = {
          hero: 'right', features: 'right', calculator: 'left',
          testimonials: 'right', team: 'left', pricing: 'right',
          faq: 'left', contact: 'right',
        };

        function getVisibleSection(): string {
          for (const id of sections) {
            const el = document.getElementById(id);
            if (!el) continue;
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight * 0.6 && rect.bottom > window.innerHeight * 0.2) {
              return id;
            }
          }
          return '';
        }

        setTimeout(() => {
          mascotContainer?.classList.add('visible');
          const greeting = greetings[Math.floor(Math.random() * greetings.length)];
          showBubble(greeting, 'teeth');
          currentSection = 'hero';
          setSide('right');
        }, 1200);

        let scrollCooldown = false;
        window.addEventListener('scroll', () => {
          if (scrollCooldown) return;
          const visible = getVisibleSection();
          if (!visible) return;
          if (visible !== currentSection) {
            currentSection = visible;
            setSide(sectionSides[visible] || 'right');
            const lines = sectionDialogue[visible];
            if (lines && lines.length > 0) {
              scrollCooldown = true;
              setTimeout(() => {
                const line = lines[Math.floor(Math.random() * lines.length)];
                showBubble(line.text, line.expr);
                scrollCooldown = false;
              }, 400);
            }
          }
        });
      })();
    </script>
  </body>
</html>
